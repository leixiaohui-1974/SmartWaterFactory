# MCP服务环境变量配置
# 复制此文件为 .env 并根据实际情况修改

# 服务器配置
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_DEBUG=false

# 认证配置
MCP_ENABLE_AUTH=true

# 性能配置
MCP_MAX_SESSIONS=100
MCP_SESSION_TIMEOUT=30
MCP_RATE_LIMIT=60

# 资源限制
MCP_MAX_SIMULATION_STEPS=10000
MCP_MAX_SIMULATION_DURATION=60
MCP_MAX_CONCURRENT_SIMULATIONS=5

# 日志配置
MCP_LOG_LEVEL=INFO
MCP_LOG_FILE=logs/mcp_service.log

# 存储配置
MCP_DATA_DIR=data/mcp
MCP_TEMP_DIR=temp/mcp
MCP_CACHE_ENABLED=true
MCP_CACHE_TTL=300
