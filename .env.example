# ===================================
# SmartWaterFactory 环境变量配置模板
# ===================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# -----------------------------------
# 应用环境配置
# -----------------------------------
# 环境类型: development, testing, production
WATER_PLANT_ENV=development

# 调试模式 (仅开发环境使用)
DEBUG=true

# -----------------------------------
# API服务器配置
# -----------------------------------
# API服务器主机地址
API_HOST=127.0.0.1

# API服务器端口
API_PORT=5000

# JWT密钥 (生产环境必须更改！)
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production

# JWT令牌过期时间（小时）
JWT_EXPIRATION_HOURS=24

# 启用API认证
ENABLE_AUTHENTICATION=true

# 启用WebSocket
ENABLE_WEBSOCKET=true

# API速率限制（每分钟请求数）
RATE_LIMIT_PER_MINUTE=60

# CORS允许的源
CORS_ORIGINS=*

# -----------------------------------
# 用户认证配置
# -----------------------------------
# 管理员用户配置 (生产环境必须更改！)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# 操作员用户配置
OPERATOR_USERNAME=operator
OPERATOR_PASSWORD=change-this-password

# 普通用户配置
USER_USERNAME=user
USER_PASSWORD=change-this-password

# -----------------------------------
# 数据库配置 (可选，用于数据持久化)
# -----------------------------------
# 数据库类型: postgresql, sqlite
DATABASE_TYPE=sqlite

# PostgreSQL配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=waterplant
DB_USER=postgres
DB_PASSWORD=your-db-password

# 数据库连接池配置
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# SQLite配置
SQLITE_PATH=data/waterplant.db

# -----------------------------------
# Redis配置 (可选，用于缓存)
# -----------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Redis连接URL (可选，优先于上述配置)
# REDIS_URL=redis://localhost:6379/0

# -----------------------------------
# 日志配置
# -----------------------------------
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/water_plant.log

# 启用控制台日志
ENABLE_CONSOLE_LOG=true

# 启用文件日志
ENABLE_FILE_LOG=true

# 日志文件最大大小 (MB)
LOG_MAX_FILE_SIZE=10

# 日志文件备份数量
LOG_BACKUP_COUNT=5

# 日志格式: text, json, structured
LOG_FORMAT=structured

# -----------------------------------
# 仿真配置
# -----------------------------------
# 默认仿真步数
DEFAULT_SIMULATION_STEPS=100

# 最大仿真步数
MAX_SIMULATION_STEPS=10000

# 仿真时间步长
SIMULATION_TIME_STEP=1.0

# 输出目录
OUTPUT_DIRECTORY=outputs

# 启用实时仿真
ENABLE_REAL_TIME=false

# 启用性能监控
PERFORMANCE_MONITORING=false

# 启用噪声
ENABLE_NOISE=false

# 噪声水平
NOISE_LEVEL=0.01

# 启用扰动
ENABLE_DISTURBANCES=false

# -----------------------------------
# 监控和告警配置
# -----------------------------------
# Prometheus端口
PROMETHEUS_PORT=9090

# Grafana端口
GRAFANA_PORT=3000

# 启用告警
ENABLE_ALERTS=false

# 告警邮箱
ALERT_EMAIL=

# -----------------------------------
# Celery配置 (可选，用于异步任务)
# -----------------------------------
# Celery broker URL
CELERY_BROKER_URL=redis://localhost:6379/1

# Celery result backend
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# -----------------------------------
# 安全配置
# -----------------------------------
# 最大登录尝试次数
MAX_LOGIN_ATTEMPTS=5

# 登录锁定时间（分钟）
LOGIN_LOCKOUT_MINUTES=15

# 启用速率限制
ENABLE_RATE_LIMITING=true

# -----------------------------------
# 其他配置
# -----------------------------------
# 时区
TIMEZONE=Asia/Shanghai

# 语言
LANGUAGE=zh-CN

# 数据保留天数
DATA_RETENTION_DAYS=90
